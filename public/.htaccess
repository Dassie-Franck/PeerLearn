Options -Indexes
RewriteEngine On

# Fichiers et dossiers physiques → servis directement (CSS, JS, images)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Tout segment /xxx → index.php?url=xxx
RewriteRule ^([^/]+)/?$ index.php?url=$1 [QSA,L]

# Racine / → index.php
RewriteRule ^$ index.php [L]